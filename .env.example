# Copy to .env and fill in for your setup. Used by the scripts.

# The doorbell's IP on your LAN, and its ONVIF port (Reolink default: 8000)
CAMERA_IP=192.168.1.50
ONVIF_PORT=8000

# go2rtc API base (Frigate's bundled go2rtc listens on 1984).
# Use the host/IP your Home Assistant container can reach.
GO2RTC_URL=http://192.168.1.10:1984

# go2rtc stream name we add for the send-audio backchannel
TALK_STREAM=doorbell_talk

# Where padded clips live *as seen by the go2rtc/Frigate container*
# (e.g. a path under Frigate's media mount)
CLIP_DIR_IN_CONTAINER=/media/frigate/arnold

# Frigate camera entity for the live card
CAMERA_ENTITY=camera.doorbell
